# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/alhyaah-uploads

# Server Configuration
PORT=5000
NODE_ENV=development

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,txt,doc,docx,xls,xlsx

# Application
APP_NAME=ALhyaah File Upload System
APP_VERSION=1.0.0